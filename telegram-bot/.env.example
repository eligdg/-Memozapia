# Token de Telegram Bot (obténlo de @BotFather)
TELEGRAM_TOKEN=tu_token_aqui

# Hugging Face Token (opcional, para IA real)
HUGGINGFACE_TOKEN=

# Google OAuth2 Credentials
# 1. Ve a https://console.cloud.google.com/
# 2. Crea proyecto y habilita: Google Calendar API, Gmail API
# 3. Crea credenciales OAuth 2.0 (Web application)
# 4. En "Authorized redirect URIs" añade: http://localhost:3002/oauth2callback
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui
GOOGLE_REDIRECT_URI=http://localhost:3002/oauth2callback
